# OpenAI Configuration
# Note: Streamlit's OpenAI client will read this API key from environment variables.
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Gmail SMTP Configuration
# The sender's Gmail address (e.g. freelancer@gmail.com)
GMAIL_SENDER=your_gmail_sender@gmail.com
# The 16-character Google App Password (not your main password)
GMAIL_APP_PASS=your_gmail_app_password_here

# Freelancer Business Defaults
FREELANCER_NAME=Alex Morgan
FREELANCER_EMAIL=alex.morgan@gmail.com
FREELANCER_BANK_DETAILS=Bank of America, Account: XXXXX-12345, Routing: YYYYY-67890
